{
  "printWidth": 150,
  "singleAttributePerLine": false,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "semi": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "overrides": [
    {
      "files": "*.xml",
      "options": {
        "xmlSelfClosingSpace": false,
        "xmlWhitespaceSensitivity": "ignore"
      }
    }
  ]
}
